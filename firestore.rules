rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Default deny
    match /{document=**} {
      allow read, write: if false;
    }

    // Connection test path
    match /_connection_test_/{docId} {
      allow read: if true;
    }

    // ===============================================================
    // Helper Functions
    // ===============================================================
    
    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function isAdmin() {
      return isAuthenticated() && 
        (
          (request.auth.token.email != null && request.auth.token.email.lower() == "mosinjonovjasurbek00@gmail.com") ||
          (exists(/databases/$(database)/documents/users/$(request.auth.uid)) && 
           get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin')
        );
    }

    function isValidAnime(data) {
      return data.keys().hasAll(['title', 'posterUrl', 'category', 'type', 'createdAt', 'authorUid']) &&
             data.title is string && data.title.size() <= 200 &&
             data.posterUrl is string &&
             data.category is string &&
             data.type in ['movie', 'series'] &&
             data.authorUid == request.auth.uid;
    }

    function isValidEpisode(data) {
      return data.keys().hasAll(['animeId', 'episodeNumber', 'videoUrl', 'createdAt']) &&
             data.animeId is string &&
             data.episodeNumber is number &&
             data.videoUrl is string &&
             (!('openingStart' in data) || data.openingStart is number) &&
             (!('openingEnd' in data) || data.openingEnd is number);
    }

    function isValidComment(data) {
      return data.keys().hasAll(['userId', 'username', 'content', 'createdAt']) &&
             data.userId == request.auth.uid &&
             data.username is string &&
             data.content is string &&
             data.content.size() >= 1 &&
             data.content.size() <= 1000;
    }

    function isValidNotification(data) {
      return data.keys().hasAll(['type', 'title', 'message', 'animeId', 'createdAt']) &&
             data.type in ['anime', 'episode'] &&
             data.title is string && data.title.size() <= 200 &&
             data.message is string && data.message.size() <= 500 &&
             data.animeId is string;
    }

    function isValidHistory(data) {
      return data.keys().hasAll(['userId', 'animeId', 'episodeId', 'episodeNumber', 'updatedAt']) &&
             data.userId == request.auth.uid &&
             data.animeId is string &&
             data.episodeId is string &&
             data.episodeNumber is number &&
             data.updatedAt == request.time;
    }

    // ===============================================================
    // Rules
    // ===============================================================

    match /users/{userId} {
      allow read: if isAuthenticated();
      // Allow creation if the user is authenticated (matching their own UID)
      allow create: if isAuthenticated() && request.auth.uid == userId;
      // Allow update for role change by admin, or user updating their own profile (preventing self-promotion to admin)
      allow update: if isAdmin() || (isOwner(userId) && request.resource.data.role == resource.data.role);
      allow delete: if isAdmin();
    }

    match /anime/{animeId} {
      allow read: if true;
      allow create: if isAdmin() && isValidAnime(request.resource.data);
      allow delete, update: if isAdmin();

      match /episodes/{episodeId} {
        allow read: if true;
        allow create, update: if isAdmin() && isValidEpisode(request.resource.data);
        allow delete: if isAdmin();
      }

      match /comments/{commentId} {
        allow read: if true;
        allow create: if isAuthenticated() && isValidComment(request.resource.data);
        allow delete: if isAdmin() || (isAuthenticated() && resource.data.userId == request.auth.uid);
      }
    }

    match /ads/{adId} {
      allow read: if true;
      allow create, update, delete: if isAdmin();
    }

    match /watchlist/{id} {
      allow read: if isAuthenticated() && (resource == null || resource.data.userId == request.auth.uid);
      allow create: if isAuthenticated() && request.resource.data.userId == request.auth.uid;
      allow delete: if isAuthenticated() && resource.data.userId == request.auth.uid;
    }

    match /messages/{messageId} {
      allow create: if true;
      allow read, delete: if isAdmin();
    }

    match /public_notifications/{notificationId} {
      allow read: if true;
      allow create: if isAdmin() && isValidNotification(request.resource.data);
      allow delete: if isAdmin();
      allow update: if false;
    }

    match /history/{id} {
      allow read: if isAuthenticated() && (resource == null || resource.data.userId == request.auth.uid);
      allow create, update: if isAuthenticated() && isValidHistory(request.resource.data);
      allow delete: if isAuthenticated() && resource.data.userId == request.auth.uid;
    }

    match /fcm_tokens/{tokenId} {
      allow read: if isAdmin();
      allow create, update: if isAuthenticated();
      allow delete: if isAdmin() || (isAuthenticated() && request.auth.uid == resource.data.userId); // Adjust logic if needed
    }
  }
}
