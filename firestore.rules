rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // 0. Default Deny Catch-all
    match /{document=**} {
      allow read, write: if false;
    }

    // 0.1 Connection Test
    match /_connection_test_/{docId} {
      allow read: if true;
    }

    // ===============================================================
    // Section 1: Global Safety Primitives
    // ===============================================================

    function isSignedIn() { return request.auth != null; }
    function isOwner(userId) { return isSignedIn() && request.auth.uid == userId; }
    function isValidId(id) { return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$'); }
    
    // Admin check: Prioritizes verified email for high-privilege access
    function isAdmin() { 
      return isSignedIn() && (
        (request.auth.token.email != null && 
         request.auth.token.email == "mosinjonovjasurbek00@gmail.com") ||
        (exists(/databases/$(database)/documents/users/$(request.auth.uid)) && 
         get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin')
      );
    }

    function incoming() { return request.resource.data; }
    function existing() { return resource.data; }

    // ===============================================================
    // Section 2: Entity Validation Blueprints
    // ===============================================================

    function isValidAnime(data) {
      return data.keys().hasAll(['title', 'posterUrl', 'category', 'type', 'createdAt', 'authorUid']) &&
             data.title is string && data.title.size() <= 200 &&
             data.posterUrl is string && data.posterUrl.size() <= 1000 &&
             data.category is string &&
             data.type in ['movie', 'series'] &&
             data.authorUid == request.auth.uid;
    }

    function isValidEpisode(data) {
      return data.keys().hasAll(['animeId', 'episodeNumber', 'videoUrl', 'createdAt']) &&
             data.animeId is string && data.animeId.size() <= 64 &&
             data.episodeNumber is number &&
             data.videoUrl is string && data.videoUrl.size() <= 2000;
    }

    function isValidComment(data) {
      return data.keys().hasAll(['userId', 'username', 'content', 'createdAt']) &&
             data.userId == request.auth.uid &&
             data.username is string && data.username.size() <= 100 &&
             data.content is string && data.content.size() >= 1 && data.content.size() <= 2000;
    }

    function isValidChatMessage(data) {
      return data.keys().hasAll(['userId', 'username', 'content', 'type', 'role', 'createdAt']) &&
             data.userId == request.auth.uid &&
             data.username is string && data.username.size() <= 100 &&
             data.content is string && data.content.size() >= 1 && data.content.size() <= 2000 &&
             data.type in ['text', 'sticker'] &&
             data.createdAt == request.time;
    }

    function isValidUser(data) {
      return data.keys().hasAll(['uid', 'email', 'updatedAt']) &&
             data.uid == request.auth.uid &&
             data.email is string && data.email.size() <= 128;
    }

    // ===============================================================
    // Section 3: Hardened Rulesets
    // ===============================================================

    // [Pillar 6: PII Isolation] Users collection contains emails
    match /users/{userId} {
      allow get: if isSignedIn() && (isOwner(userId) || isAdmin());
      // Only admins can list users
      allow list: if isAdmin();
      
      allow create: if isOwner(userId) && 
                      isValidUser(incoming()) && 
                      incoming().role == 'user'; // Prevent self-elevation on create
      
      allow update: if (
        isAdmin() || 
        (isOwner(userId) && 
         isValidUser(incoming()) && 
         incoming().role == existing().role) // Prevent self-elevation on update
      );
      
      allow delete: if isAdmin();
    }

    match /anime/{animeId} {
      allow read: if true;
      allow create: if isAdmin() && isValidAnime(incoming());
      
      // [Pillar 4: Tiered Identity] Admins can manage all, others can only increment views
      allow update: if isAdmin() || (
        incoming().diff(existing()).affectedKeys().hasOnly(['views']) &&
        incoming().views == existing().views + 1
      );
      allow delete: if isAdmin();

      match /episodes/{episodeId} {
        allow read: if true;
        allow create: if isAdmin() && isValidEpisode(incoming());
        allow update: if isAdmin() && isValidEpisode(incoming());
        allow delete: if isAdmin();
      }

      match /comments/{commentId} {
        allow read: if true;
        allow create: if isSignedIn();
        allow delete: if isAdmin() || (isSignedIn() && existing().userId == request.auth.uid);
      }
    }

    match /watchlist/{id} {
      // [Pillar 8: Secure List Queries] Force filter by userId
      allow list: if isSignedIn() && resource.data.userId == request.auth.uid;
      allow get: if isSignedIn() && existing().userId == request.auth.uid;
      
      allow create: if isSignedIn() && 
                    incoming().userId == request.auth.uid &&
                    exists(/databases/$(database)/documents/anime/$(incoming().animeId));
      
      allow delete: if isSignedIn() && existing().userId == request.auth.uid;
    }

    match /history/{id} {
      allow list: if isSignedIn() && resource.data.userId == request.auth.uid;
      allow get: if isSignedIn() && existing().userId == request.auth.uid;
      
      allow create: if isSignedIn() && 
                    incoming().userId == request.auth.uid &&
                    incoming().updatedAt == request.time;
      
      allow update: if isSignedIn() && 
                    existing().userId == request.auth.uid &&
                    incoming().userId == request.auth.uid &&
                    incoming().updatedAt == request.time &&
                    incoming().diff(existing()).affectedKeys().hasOnly(['episodeId', 'episodeNumber', 'updatedAt']);
      
      allow delete: if isSignedIn() && existing().userId == request.auth.uid;
    }

    match /messages/{messageId} {
      allow create: if incoming().size() <= 10 && 
                      incoming().message.size() <= 5000;
      allow read, delete: if isAdmin();
    }

    match /public_notifications/{notificationId} {
      allow read: if true;
      allow create, delete: if isAdmin();
    }

    match /ads/{adId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /fcm_tokens/{tokenId} {
      allow read: if isAdmin();
      allow write: if isSignedIn() && (incoming().userId == request.auth.uid || existing().userId == request.auth.uid);
    }

    match /chat_messages/{messageId} {
      allow read: if true;
      allow create: if isSignedIn() && isValidChatMessage(incoming()) && (
        (incoming().role == 'admin' && isAdmin()) ||
        (incoming().role == 'user')
      );
      allow delete: if isAdmin() || (isSignedIn() && existing().userId == request.auth.uid);
    }
  }
}
