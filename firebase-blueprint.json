{
  "entities": {
    "Anime": {
      "title": "Anime",
      "description": "An anime series or movie document",
      "type": "object",
      "properties": {
        "title": { "type": "string", "description": "The title of the anime" },
        "posterUrl": { "type": "string", "description": "URL of the poster/thumbnail" },
        "description": { "type": "string", "description": "Summary of the anime" },
        "category": { "type": "string", "description": "The primary genre" },
        "rating": { "type": "number", "description": "User rating (0-10)" },
        "year": { "type": "number", "description": "Release year" },
        "type": { "type": "string", "enum": ["movie", "series"], "description": "Type of content" },
        "status": { "type": "string", "enum": ["ongoing", "finished"], "description": "Current status" },
        "episodesCount": { "type": "number", "description": "Total episodes" },
        "createdAt": { "type": "string", "format": "date-time", "description": "Upload timestamp" },
        "authorUid": { "type": "string", "description": "Admin UID" },
        "views": { "type": "number", "description": "Total view count" }
      },
      "required": ["title", "posterUrl", "category", "type", "createdAt", "authorUid"]
    },
    "Episode": {
      "title": "Episode",
      "description": "A single anime episode",
      "type": "object",
      "properties": {
        "animeId": { "type": "string", "description": "ID of parent anime" },
        "episodeNumber": { "type": "number", "description": "Episode sequence" },
        "title": { "type": "string", "description": "Episode title (optional)" },
        "videoUrl": { "type": "string", "description": "URL to play the episode" },
        "openingStart": { "type": "number", "description": "Start of opening in seconds" },
        "openingEnd": { "type": "number", "description": "End of opening in seconds" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["animeId", "episodeNumber", "videoUrl", "createdAt"]
    },
    "Watchlist": {
      "title": "Watchlist",
      "description": "A user's saved anime",
      "type": "object",
      "properties": {
        "userId": { "type": "string", "description": "User UID" },
        "animeId": { "type": "string", "description": "Anime UID" },
        "createdAt": { "type": "string", "format": "date-time", "description": "When added" }
      },
      "required": ["userId", "animeId", "createdAt"]
    },
    "User": {
      "title": "User",
      "description": "User profile",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "email": { "type": "string" },
        "username": { "type": "string" },
        "photoURL": { "type": "string" },
        "role": { "type": "string", "enum": ["admin", "user"] }
      },
      "required": ["uid", "role"]
    },
    "Message": {
      "title": "Message",
      "description": "A contact message from a user",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "email": { "type": "string" },
        "contact": { "type": "string", "description": "Telegram or Phone" },
        "message": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" },
        "status": { "type": "string", "enum": ["new", "read", "resolved"] }
      },
      "required": ["name", "email", "contact", "message", "createdAt"]
    },
    "Comment": {
      "title": "Comment",
      "description": "User comment on an anime",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "username": { "type": "string" },
        "content": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["userId", "username", "content", "createdAt"]
    },
    "Notification": {
      "title": "Notification",
      "description": "Public site notification for new content",
      "type": "object",
      "properties": {
        "type": { "type": "string", "enum": ["anime", "episode"] },
        "title": { "type": "string" },
        "message": { "type": "string" },
        "posterUrl": { "type": "string" },
        "animeId": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["type", "title", "message", "animeId", "createdAt"]
    },
    "History": {
      "title": "History",
      "description": "User's watch history",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "animeId": { "type": "string" },
        "episodeId": { "type": "string" },
        "episodeNumber": { "type": "number" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["userId", "animeId", "episodeNumber", "updatedAt"]
    }
  },
  "firestore": {
    "/anime/{animeId}": {
      "schema": "Anime",
      "description": "Database of anime titles"
    },
    "/anime/{animeId}/episodes/{episodeId}": {
      "schema": "Episode",
      "description": "Collection of episodes for a specific anime"
    },
    "/anime/{animeId}/comments/{commentId}": {
      "schema": "Comment",
      "description": "User comments for a specific anime"
    },
    "/users/{userId}": {
      "schema": "User",
      "description": "User profiles"
    },
    "/watchlist/{watchlistId}": {
      "schema": "Watchlist",
      "description": "User personal watchlists"
    },
    "/messages/{messageId}": {
      "schema": "Message",
      "description": "Inbound contact form messages"
    },
    "/public_notifications/{notificationId}": {
      "schema": "Notification",
      "description": "Global notifications for all users"
    },
    "/history/{historyId}": {
      "schema": "History",
      "description": "User viewing progress"
    }
  }
}
